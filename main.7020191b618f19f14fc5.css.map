@media (min-width: 600px) {

    .loading-page {
        background-size: 265px, 100%, cover;
    }

    .onboarding-page__image {
        width: 318px;
        height: 302px;
    }

    .onboarding-page_type_rules {
        background-size: 280px, cover;
    }

    .onboarding-page__content {
        min-height: 390px;
        padding-left: 25px;
        padding-right: 25px;
        padding-bottom: 25px;
    }

    .onboarding-page__buttons {
        flex-direction: row-reverse;
        grid-gap: 20px;
    }

    .onboarding-page__text {
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .docs-modal {
        width: 375px;
        border-radius: 20px;
        top: 0;
        bottom: 0;
        margin: auto;
    }

    .stamp-page {
        background-image: url(../images/main-bg-desktop.jpg);
    }

    .convert-wrapper__convert-block {
        width: 480px;
        height: 440px;
    }

    .convert-wrapper__stamp-block {
        width: 350px;
        height: 280px;
        top: 20px;
    }

    .convert-wrapper__label-block {
        width: 120px;
        height: 120px;
        top: 80px;
    }

    .result-page__content {
        background-size: 290px, 950px, cover;
        background-position: center calc(100% + 150px), center -200px, center;
    }

    .result-page__buttons {
        flex-direction: row-reverse;
    }

    .mail-block {
        padding-top: 70px;
        padding-left: 20px;
        padding-right: 20px;
        padding-bottom: 45px;
        margin-bottom: 30px;
    }

    .mail-block__content {
        padding-left: 35px;
        padding-right: 35px;
        padding-bottom: 30px;
    }

    .input-block__textarea_type_facts {
        height: 90px;
    }

    .input-block__textarea_type_food {
        height: 210px;
    }

    .input-block__textarea_type_custom {
        height: 180px;
    }

    .result-page_type_final .result-page__content {
        background-position: center 20dvh, center;
        background-size: 650px, cover;
    }
}