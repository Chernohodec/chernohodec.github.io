.text{
    font-weight: 400;
    text-align: center;
}

.text a{
    color: inherit;
    text-decoration: underline;
}

.text_color_black{
    color: #000000;
}

.text_color_white{
    color: #ffffff;
}

.text_color_semi-white{
    color: #FFFFFFB2;
}

.text_size_normal{
    font-size: 14px;
    line-height: 16px;
}

.text_size_big{
    font-size: 22px;
    line-height: 26px;
}

.text_align_left{
    text-align: left;
}

.text_align_center{
    text-align: center;
}