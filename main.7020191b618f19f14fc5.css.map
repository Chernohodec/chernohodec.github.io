.title {
    font-weight: 700;
    text-align: center;
    width: 100%;
}

.title_size_normal {
    font-size: 24px;
    line-height: 28px;
}

.title_size_small {
    font-size: 18px;
    line-height: 18px;
}

.title_size_xs {
    font-size: 14px;
    line-height: 14px;
}

.title_color_black {
    color: var(--black);
}

.title_color_red-gradient{
    background: linear-gradient(180deg, #E80200 0%, #920000 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.title_color_yellow-gradient{
    background: linear-gradient(180deg, #FFC30B 0%, #FF9500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.title_color_white {
    color: #fff;
}

.title_color_black {
    color: #000000;
}

.title_align_center{
    text-align: center;
}

.title_align_left{
    text-align: left;
}

