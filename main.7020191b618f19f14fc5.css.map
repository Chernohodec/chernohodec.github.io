@font-face {
    font-family: "YSGeo";
    src: url("../fonts/YSGeo-Regular/YSGeo-Regular.eot");
    src: url("../fonts/YSGeo-Regular/YSGeo-Regular.eot?#iefix")format("embedded-opentype"),
        url("../fonts/YSGeo-Regular/YSGeo-Regular.woff")format("woff"),
        url("../fonts/YSGeo-Regular/YSGeo-Regular.woff2")format("woff2"),
        url("../fonts/YSGeo-Regular/YSGeo-Regular.ttf")format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
}


@font-face {
    font-family: "YSGeo";
    src: url("../fonts/YSGeo-Bold/YSGeo-Bold.eot");
    src: url("../fonts/YSGeo-Bold/YSGeo-Bold.eot?#iefix")format("embedded-opentype"),
        url("../fonts/YSGeo-Bold/YSGeo-Bold.woff")format("woff"),
        url("../fonts/YSGeo-Bold/YSGeo-Bold.woff2")format("woff2"),
        url("../fonts/YSGeo-Bold/YSGeo-Bold.ttf")format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
}

:root {
    --white: #FFFFFF;
    --yellow: #FFD700;
    --black: #000000;
    --grey: #F5F5F5;

}

* {
    box-sizing: border-box;
    outline: none !important;
}

img {
    -drag: none;
    user-select: none;
    -moz-user-select: none;
    -webkit-user-drag: none;
    -webkit-user-select: none;
    -ms-user-select: none;
}


ul,
ol,
p,
div,
label,
h1,
h2,
h3 {
    list-style: none;
    padding: 0;
    margin: 0;
}

button,
button span {
    cursor: pointer;
    background-color: transparent;
    border: none;
    padding: 0;
    -webkit-tap-highlight-color: rgba(255, 255, 255, 0);
    -webkit-tap-highlight-color: transparent;
    user-select: none;
}

a,
a:hover {
    text-decoration: none;
}

body,
html {
    font-family: 'YSGeo', sans-serif;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    font-weight: 400;
    /* height: 100%; */
}

.app {
    height: 100%;
}

.overlay {
    position: fixed;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal {
    width: 100%;
    /* min-height: 310px; */
    display: flex;
    flex-direction: column;
}

.docs-modal {
    margin-top: auto;
    background-color: var(--white);
    border-radius: 20px 20px 0 0;
    position: relative;
    padding-top: 25px;
    padding-left: 12px;
    padding-right: 12px;
    padding-bottom: 12px;
}

.modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--grey);
}

.docs-modal__title {
    margin-bottom: 25px;
}

.container {
    width: 100%;
    min-height: 100vh;
    height: auto;
    overflow: auto;
    position: relative;
    /* position: fixed;
    left: 0;
    top: 0; */
}

.docs-modal__buttons {
    display: flex;
    flex-direction: column;
    grid-gap: 10px;
}

.loading-page {
    background-image: url(../images/loader-pic-shadow.png), url(../images/loading-cloud.png), url(../images/onboarding-bg.jpg);
    background-size: 265px, 820px, auto 100%;
    background-repeat: no-repeat;
    background-position: center, center 0, center 100%;
    /* background-size: 100% 100%; */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    padding-top: 40px;
    padding-bottom: 50px;
}

.loading-page:after {
    content: '';
    position: absolute;
    width: 100%;
    height: 220px;
    display: flex;
}

.loading-page:before {
    background: linear-gradient(360deg, rgba(16, 19, 50, 0.49) 0%, rgba(16, 19, 50, 0) 95.5%);
    box-shadow: 0px 4px 4px 0px #00000040;
    left: 0;
    top: 0;
    transform: rotate(180deg);
}


.loading-page:after {
    background: linear-gradient(360deg, rgba(16, 19, 50, 0.49) 0%, rgba(16, 19, 50, 0) 95.5%);
    box-shadow: 0px 4px 4px 0px #00000040;
    left: 0;
    bottom: 0;
}


.loading-page__loading-block {
    margin-left: auto;
    margin-right: auto;
}

.loading-block {
    max-width: 360px;
    width: 100%;
    height: 10px;
    background: #FFFFFF80;
    border-radius: 5px;
    position: relative;
    z-index: 2;
}

.loading-block__bar {
    height: 100%;
    background: var(--yellow);
    border-radius: 5px;
    width: 0;
    animation: loading 2.5s;
    animation-fill-mode: forwards;
}

.loading-page__main-pic {
    position: relative;
    z-index: 2;
}

@keyframes loading {
    from {
        width: 0;
    }

    to {
        width: 100%;
    }
}

.onboarding-page {
    background-image: url(../images/onboarding-bg.jpg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    display: flex;
}

.onboarding-page__content {
    display: flex;
    flex-direction: column;
    margin-top: auto;
    background-image: url(../images/onboarding-content-bg.png);
    background-repeat: no-repeat;
    background-size: auto 100%;
    background-position: center 0;
    padding-top: 15vh;
    padding-left: 12px;
    padding-right: 12px;
    padding-bottom: 30px;
    min-height: 60dvh;
    position: relative;
    width: 100%;
}

.onboarding-page__image {
    position: absolute;
    left: 0;
    right: 0;
    margin: auto;
    bottom: calc(100% - 100px);
}

.onboarding-page__title {
    margin-bottom: 15px;
    margin-top: auto;
}

.onboarding-page__text {
    margin-bottom: 20px;
}

.onboarding-page__button {
    margin-top: auto;
}

.onboarding-page__buttons {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    grid-gap: 8px;
}

.onboarding-page_type_start {
    background-image: url(../images/onboarding-bg.jpg);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
}

.onboarding-page_type_rules {
    background-image: url(../images/onboarding-pic2.png), url(../images/onboarding-bg.jpg);
    background-repeat: no-repeat;
    background-size: 300px, cover;
    background-position: center 0, center;
}

.main-page {
    background-image: url(../images/main-bg-xs.jpg);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    overflow: hidden;
}

.main-page_active {
    background-image: url(../images/main-bg-active.jpg);
    background-repeat: no-repeat;
    background-position: center 0;
    background-repeat: no-repeat;
    background-size: 100% 100%;
}

.mail-block {
    display: flex;
    flex-direction: column;
    justify-content: stretch;
    position: relative;
    width: calc(100% - 24px);
    /* height: 870px; */
    margin-left: auto;
    margin-right: auto;
    margin-top: 85px;
    background-image: url(../images/main-bg-xs.jpg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    border-radius: 25px;
    padding: 45px 12px 30px;
    max-width: 570px;
    margin-left: auto;
    margin-right: auto;
}

.mail-block__content {
    background-color: var(--white);
    border-radius: 25px;
    height: 100%;
    padding-top: 10px;
    padding-left: 18px;
    padding-right: 18px;
    padding-bottom: 60px;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: calc(100dvh - 160px);
}

.mail-block__title {
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 30px;
}

.mail-block__button {
    box-shadow: 0px 4px 25.4px 0px #FFD700A1;
    margin-top: 60px;
    position: relative;
    z-index: 2;
}

.mail-block__letter {
    position: absolute;
    left: -50px;
    top: -25px;
    width: 160px;
    height: 130px;
    background-image: url(../images/letter.png);
    background-repeat: no-repeat;
    background-size: contain;
}

.mail-block__skis {
    position: absolute;
    right: -60px;
    top: -50px;
    width: 150px;
    height: 150px;
    background-image: url(../images/skis.png);
    background-repeat: no-repeat;
    background-size: contain;
}

.mail-block__iceman {
    position: absolute;
    left: -50px;
    bottom: -40px;
    width: 190px;
    height: 190px;
    background-image: url(../images/static/onboarding-pic1.png);
    background-repeat: no-repeat;
    background-size: contain;
    z-index: 3;
}

.mail-block__bag {
    position: absolute;
    right: -60px;
    bottom: -10px;
    width: 170px;
    height: 200px;
    background-image: url(../images/sag.png);
    background-repeat: no-repeat;
    background-size: contain;
    transform: rotate(-15deg);
}

.stamp-page {
    background-image: url(../images/main-bg-xs.jpg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    display: flex;
    overflow: hidden;
}

.convert-wrapper {
    width: 100%;
    height: 380px;
    margin-top: auto;
    margin-bottom: auto;
    position: relative;
}

.convert-wrapper__convert-block {
    width: 360px;
    height: 360px;
    margin-left: auto;
    margin-right: auto;
    background-image: url(../images/stamp-letter.png);
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    z-index: 1;
}

.convert-wrapper__stamp-block {
    width: 260px;
    height: 170px;
    background-image: url(../images/stamp.png);
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% auto;
    position: absolute;
    left: 0;
    right: 0;
    margin: auto;
    top: 0;
    bottom: 0;
    z-index: 3;
    animation: stamp 2.5s;
    animation-fill-mode: forwards;
}

.convert-wrapper__label-block {
    width: 90px;
    height: 90px;
    background-image: url(../images/stamp-label.png);
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% auto;
    position: absolute;
    left: 0;
    right: 0;
    margin: auto;
    top: 0;
    bottom: 0;
    z-index: 2;
    opacity: 0;
    animation: label 2.5s;
    animation-fill-mode: forwards;
}

@keyframes stamp {
    0% {
        transform: scale(1.5) translateX(200px);
        opacity: 0;
    }

    50% {
        transform: scale(1) translateX(70px);
        opacity: 1;
    }

    100% {
        transform: scale(1.5) translateX(140px);
        opacity: 0;
    }
}

@keyframes label {
    0% {
        opacity: 0;
    }

    50% {
        opacity: 0;
    }

    100% {
        opacity: 1;
    }
}

.result-page {
    background-color: var(--yellow);
    padding: 12px;
}

.result-page__content {
    border-radius: 32px;
    height: calc(100dvh - 24px);
    overflow: hidden;
    background-image: url(../images/onboarding-pic2.png), url(../images/result-cloud.png), url(../images/main-bg-xs.jpg);
    background-repeat: no-repeat;
    background-position: center calc(100% + 100px), center -300px, center;
    background-size: 40vh, 1200px, cover;
    display: flex;
    flex-direction: column;
    padding-bottom: 15px;
    padding-left: 15px;
    padding-right: 15px;
}

.result-page__logo {
    width: max-content;
    display: flex;
    margin-left: auto;
    margin-right: auto;
    background-color: var(--yellow);
    padding-left: 20px;
    padding-right: 20px;
    padding-top: 5px;
    padding-bottom: 12px;
    border-radius: 0 0 32px 32px;
    margin-bottom: 5vh;
}

.result-page__letter {
    margin-left: auto;
    margin-right: auto;
    display: flex;
    margin-bottom: 10px;
}

.result-page__title {
    margin-bottom: 5px;
}

.result-page__buttons {
    display: flex;
    flex-direction: column;
    grid-gap: 10px;
    margin-top: auto;
}

.result-page__button {
    margin-top: auto;
    box-shadow: 0px 4px 25.4px 0px #FFD700A1;
    margin-left: auto;
    margin-right: auto;
}

.result-page__text {
    margin-bottom: 15px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
}

.mail-stop {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 40px 40px;
    background-image: url(../images/cloud.png);
    background-repeat: no-repeat;
    background-position: center;
    background-size: 535px;
}

.mail-stop__sag {
    width: 105px;
    height: 154px;
    background-repeat: no-repeat;
    background-image: url(../images/sag.png);
    background-size: contain;
    margin-bottom: 13px;
    margin-top: auto;
}

.mail-stop__text{
    margin-top: 5px;
}

.mail-stop__button {
    margin-top: auto;
    box-shadow: 0px 4px 25.4px 0px #FFD700A1;
}

.result-page__value {
    width: 180px;
    height: 48px;
    background-color: var(--yellow);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    margin-right: auto;
    font-size: 14px;
    line-height: 14px;
    font-weight: 700;
    grid-gap: 8px;
}

.result-page__value span {
    font-size: 18px;
    line-height: 1;
    margin-bottom: 2px;
}

.mail-block__description {
    margin-bottom: 25px;
}


.input-block__caption {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 7px;
}

.input-block__caption span{
    color: #999999;
    font-weight: 400;
}

.input-block__input {
    height: 32px;
    background-color: transparent;
    border: none;
    border-bottom: 1px solid #000000;
    display: flex;
    width: 100%;
    font-size: 15px;
    color: #000;
    font-weight: 400;
    padding: 0;
    border-radius: 0;
}

.input-block__input::placeholder,
.input-block__textarea::placeholder {
    color: #00000033;
}

.main-form .input-block:not(:last-child) {
    margin-bottom: 32px;
}

.input-block__textarea {
    background-color: transparent;
    border: none;
    display: flex;
    width: 100%;
    font-size: 15px;
    line-height: 2;
    color: #000;
    font-weight: 400;
    padding: 0;
    /* background-image: url(../images/textarea-lines.svg);
    background-repeat: no-repeat;
    background-size: 470px;
    background-position: 0 25px; */
    resize: none;
    overflow: hidden;
    line-height: 3ch;
    background-image: linear-gradient(transparent, transparent calc(3ch - 1px), #000000 0px);
    background-size: 100% 3ch;
}

.input-block__textarea_type_facts {
    height: 160px;
}

.input-block__textarea_type_food {
    height: 360px;
}

.input-block__textarea_type_custom {
    height: 240px;
}

.result-page_type_final .result-page__content{
    background-image: url(../images/result-cloud.png), url(../images/main-bg-xs.jpg);
    background-position: center 26dvh, center;
    background-size: 600px, cover;
}

.result-page__final-block{
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
}

.result-page__final-block{
    margin-top: auto;
    margin-bottom: auto;
}

.result-page__skis{
    margin-left: auto;
    margin-right: auto;
    display: flex;
    transform: rotate(20deg);
}