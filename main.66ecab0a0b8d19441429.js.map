import bridge from "@vkontakte/vk-bridge";

export const checkGroupMessagesAllowed = async () => {
    try {
        const data = await bridge.send('VKWebAppAllowMessagesFromGroup', {
            group_id: 118335773,
        })
        return data;
    } catch (error) {
        console.log("Ошибка VKWebAppAllowMessagesFromGroup:", error);
    }
};
