import React from 'react';
import { useDispatch } from "react-redux";
import { Button } from '../components/Button/Button';
import { Text } from '../components/Text/Text';
import { Title } from '../components/Title/Title';
import { setActiveModal, setActivePanel } from '../store/mainReducer';
import { postUser } from '../api/user/postUser';

const OnboardingRules = () => {

    const dispatch = useDispatch()
    const finishOnboarding = async () => {
        await postUser({onboardingIsCompleted: true})
        dispatch(setActivePanel('main'))
    }

    return (
        <div className="container onboarding-page onboarding-page_type_rules page">
            <div className="onboarding-page__content">
                <Title className={"onboarding-page__title"}>Готовы поделиться своими историями?</Title>
                <Text className={"onboarding-page__text"}>В мешке нашего Деда Мороза вас уже ждут сертификаты на 500₽ и 5000₽</Text>
                <div className="onboarding-page__buttons">
                    <Button className={"onboarding-page__button"} onClick={finishOnboarding}>Принять и написать письмо</Button>
                    <Button color='white' className={"onboarding-page__button"} onClick={() => dispatch(setActiveModal('docs'))}>Прочитать правила</Button>
                </div>
            </div>
        </div>
    );
}

export default OnboardingRules;

