import { createSlice } from "@reduxjs/toolkit";

const mainSlice = createSlice({
    name: 'main',
    initialState: {
        platform: null,
        activePanel: 'loading',
        launch_params: {
        },
        history: ['loading'],
        isLoading: false,
        isFetched: false,
        activeModal: null,
        isGroupMessagesAllowed: false,
        onboardingCompleted: false,
        notificationIsAllowed: false,
        isLetterSend: false,
        letters: 0,
        appIsOpen: true,
    },
    reducers: {
        setLaunchParams(state, action) {
            state.launch_params = action.payload
        },
        setActivePanel(state, action) {
            state.activePanel = action.payload
            state.history = [...state.history, action.payload]
        },
        setActiveModal(state, action) {
            state.activeModal = action.payload
        },
        setIsLoading(state, action){
            state.isLoading = action.payload
        },
        updateHistory(state, action){
            state.history = action.payload
        },
        setPlatform(state, action){
            state.platform = action.payload
        },
        setIsGroupMessagesAllowed(state, action){
            state.isGroupMessagesAllowed = action.payload
        },
        setIsFetched(state, action){
            state.isFetched = action.payload
        },
        setOnboardingCompleted(state, action){
            state.onboardingCompleted = action.payload
        },
        setNotificationIsAllowed(state, action){
            state.notificationIsAllowed = action.payload
        },
        setLetters(state, action){
            state.letters = action.payload
        },
        setIsLetterSend(state, action){
            state.isLetterSend = action.payload
        },
        setAppIsOpen(state, action){
            state.appIsOpen = action.payload
        },
    }
})

export default mainSlice.reducer
export const {
    setActivePanel,
    setLaunchParams,
    setActiveModal,
    setIsLoading,
    updateHistory,
    setPlatform,
    setIsGroupMessagesAllowed,
    setIsFetched,
    setOnboardingCompleted,
    setNotificationIsAllowed,
    setLetters,
    setIsLetterSend,
    setAppIsOpen
} = mainSlice.actions
