import bridge from "@vkontakte/vk-bridge";
import { postUser } from "../api/user/postUser";
import { getShare } from "../api/user/getShare";

export const shareToStory = async (image) => {
    try {
        await bridge
            .send("VKWebAppShowStoryBox", {
                background_type: "image",
                url: image,
                attachment: {
                    text: "open",
                    type: "url",
                    url: "https://vk.com/app52814233"
                },
            })
            .then((data) => {
                postUser({ isShared: true })
                getShare()
            })
            .catch((error) => {
                // Ошибка
                console.log(error);
            });
    } catch (err) {
        console.log("Ошибка выполнения VKWebAppShowStoryBox:", err);
    }
};
