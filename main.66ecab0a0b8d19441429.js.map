import React, { useEffect } from 'react';
import { useDispatch, useSelector } from "react-redux";
import { getLettersCount } from './api/user/getLettersCount';
import { getUser } from './api/user/getUser';
import ModalDocs from './modals/ModalDocs';
import Loading from './panels/Loading';
import Main from './panels/Main';
import OnboardingRules from './panels/OnboardingRules';
import OnboardingStart from './panels/OnboardingStart';
import Overlay from './panels/Overlay';
import Result from './panels/Result';
import Stamp from './panels/Stamp';
import Final from './panels/Final';
import { setAppIsOpen, setIsFetched, setIsGroupMessagesAllowed, setIsLetterSend, setLetters, setNotificationIsAllowed, setOnboardingCompleted } from './store/mainReducer';
import { getAppStatus } from './api/user/getAppStatus';


const App = () => {
  const dispatch = useDispatch()
  const activePanel = useSelector(state => state.main.activePanel)
  const activeModal = useSelector(state => state.main.activeModal)

  const init = async () => {
    const userInfo = await getUser()
    const lettersCount = await getLettersCount()
    const appStatus = await getAppStatus()
    console.log('userInfo: ', userInfo)
    dispatch(setNotificationIsAllowed(userInfo.notificationIsAllowed))
    dispatch(setOnboardingCompleted(userInfo.onboardingIsCompleted))
    dispatch(setIsGroupMessagesAllowed(userInfo.messageIsAllowed))
    if (userInfo.letter) {
      dispatch(setIsLetterSend(true))
    }
    dispatch(setAppIsOpen(appStatus ? true : false))
    dispatch(setLetters(lettersCount.letters))
    dispatch(setIsFetched(true))
  }

  useEffect(() => {
    // const hash = window.location.hash.substring(1)
    // const parsedHash = new URLSearchParams(
    //   window.location.hash.substring(1)
    // )
    init()
  }, [])

  let content = []
  if (activePanel === 'loading') {
    content.push(<Loading key='loading' />)
  } else if (activePanel === 'main') {
    content.push(<Main key='main' />)
  } else if (activePanel === 'onboardingStart') {
    content.push(<OnboardingStart key='onboardingStart' />)
  } else if (activePanel === 'onboardingRules') {
    content.push(<OnboardingRules key='onboardingRules' />)
  } else if (activePanel === 'stamp') {
    content.push(<Stamp key='stamp' />)
  } else if (activePanel === 'result') {
    content.push(<Result key='result' />)
  } else if (activePanel === 'final') {
    content.push(<Final key='final' />)
  }

  return (
    <div className={`app`}>
      <>
        {content}
        <Overlay>
          {
            activeModal === 'docs' && <ModalDocs />
          }
        </Overlay>
      </>
    </div>
  );
}
export default App;
