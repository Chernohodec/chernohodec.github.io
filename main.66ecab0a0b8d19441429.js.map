import classNames from 'classnames';
import React, { useEffect, useState } from 'react';
import { useDispatch, useSelector } from "react-redux";
import { Button } from '../components/Button/Button';
import { Text } from '../components/Text/Text';
import { Title } from '../components/Title/Title';
import { checkGroupMessagesAllowed } from '../helpers/checkGroupMessagesAllowed';
import { setActivePanel, setIsGroupMessagesAllowed, setLetters } from '../store/mainReducer';
import { postUser } from '../api/user/postUser';
import { postLetter } from '../api/user/postLetter';

const Main = () => {

    const dispatch = useDispatch()
    const isGroupMessagesAllowed = useSelector(state => state.main.isGroupMessagesAllowed)
    const [name, setName] = useState()
    const [place, setPlace] = useState()
    const [facts, setFacts] = useState()
    const [food, setFood] = useState()
    const [custom, setCustom] = useState()
    const isButtonDisabled = !(name && place && facts && food && custom)

    const sendMail = async () => {
        try {
            const letterInfo = await postLetter(`Имя: ${name} \r\n\r\nМесто: ${place} \r\n\r\nФакты: ${facts} \r\n\r\nБлюдо: ${food} \r\n\r\nТрадиция: ${custom} \r\n\r\n`)
            dispatch(setActivePanel('stamp'))
            dispatch(setLetters(letterInfo.letters))
        } catch (e) {
            console.log(e)
        }
    }

    const checkGroup = async () => {
        try {
            const checkResult = await checkGroupMessagesAllowed()
            console.log('checkGroupResult:', checkResult)
            if (checkResult.result === true) {
                dispatch(setIsGroupMessagesAllowed(true))
                postUser({ messageIsAllowed: true })
            }
        }
        catch (e) {
            dispatch(setIsGroupMessagesAllowed(false))
            postUser({ messageIsAllowed: false })
            console.log(e)
        }
    }

    useEffect(() => {
        isGroupMessagesAllowed && checkGroup()
    }, [isGroupMessagesAllowed])


    return (
        <div className={classNames("container main-page page", isGroupMessagesAllowed && 'main-page_active')}>
            {
                isGroupMessagesAllowed ?
                    <div className='mail-block'>
                        <div className="mail-block__letter"></div>
                        <div className="mail-block__skis"></div>
                        <div className="mail-block__iceman"></div>
                        <div className="mail-block__bag"></div>
                        <div className="mail-block__content">
                            <img className='mail-block__title' src="assets/images/dedoo.svg" width={135} alt="" />
                            <Text className={"mail-block__description"}>Дорогой Дедушка Мороз!</Text>
                            <div className="main-form">
                                <div className="input-block">
                                    <p className="input-block__caption">
                                        Меня зовут:
                                    </p>
                                    <input type="text" className='input-block__input' placeholder='Светлана' value={name} onChange={(e) => setName(e.target.value)} />
                                </div>
                                <div className="input-block">
                                    <p className="input-block__caption">Пишу вам из:</p>
                                    <input type="text" className='input-block__input' placeholder='д. Большой Двор Ленинградской области' value={place} onChange={(e) => setPlace(e.target.value)} />
                                </div>
                                <div className="input-block">
                                    <p className="input-block__caption">Три факта обо мне:</p>
                                    <textarea maxLength={140} className='input-block__textarea input-block__textarea_type_facts' placeholder='У меня есть кот Компот, двое внуков и я обожаю готовить шарлотку круглый год.' value={facts} onChange={(e) => setFacts(e.target.value)}>
                                    </textarea>
                                </div>
                                <div className="input-block">
                                    <p className="input-block__caption">Моё любимое новогоднее блюдо в детстве и сейчас:</p>
                                    <textarea rows={7} maxLength={320} className='input-block__textarea input-block__textarea_type_food' placeholder='Сельдь под шубой и мясо по-французски, которое мама всегда готовила из говядины с репчатым луком и сырной корочкой. Помню, как я в детстве заглядывала в духовку и всегда первой вытаскивала горячий кусочек сразу после приготовления.' value={food} onChange={(e) => setFood(e.target.value)}>
                                    </textarea>
                                </div>
                                <div className="input-block">
                                    <p className="input-block__caption">Расскажите про новогоднюю традицию, связанную с едой, которую вы принесли с собой во взрослую жизнь <span>(если вы хотите поделиться другой новогодней историей, мы будем рады её прочесть)</span></p>
                                    <textarea maxLength={280} className='input-block__textarea input-block__textarea_type_custom' value={custom} onChange={(e) => setCustom(e.target.value)}>
                                    </textarea>
                                </div>
                            </div>
                            <Button className={"mail-block__button"} onClick={sendMail} disabled={isButtonDisabled}>Отправить письмо</Button>
                        </div>
                    </div> :
                    <div className='mail-stop'>
                        <div className="mail-stop__sag"></div>
                        <Title>Чтобы продолжить, <br />разрешите доступ<br />к сообщениям</Title>
                        <Text className={'mail-stop__text'}>Это нужно, чтобы наш Дед Мороз<br/>мог связаться с победителями<br/>и вручить подарки.</Text>
                        <Button className={"mail-stop__button"} onClick={checkGroup}>Разрешить доступ</Button>
                    </div>

            }
        </div>
    );
}

export default Main;

