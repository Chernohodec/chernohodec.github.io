import React, { useEffect } from 'react';
import { useDispatch } from "react-redux";
import { setActivePanel } from '../store/mainReducer';

const Stamp = () => {

    const dispatch = useDispatch()

    useEffect(() => {
        const loading = setTimeout(() => {
            dispatch(setActivePanel('result'))
        }, 2500);
        return () => clearTimeout(loading);
    }, [])

    return (
        <div className="container stamp-page page">
            <div className="convert-wrapper">
                <div className="convert-wrapper__convert-block">

                </div>
                <div className="convert-wrapper__stamp-block">

                </div>
                <div className="convert-wrapper__label-block"></div>
            </div>
        </div>
    );
}

export default Stamp;

