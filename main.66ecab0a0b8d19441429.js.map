import React from "react"
import classNames from "classnames"
import './Text.css'

export const Text = ({ children, size = "normal", color = "black", align = "center", className }) =>
    <p className={
        classNames(
            "text",
            size && `text_size_${size}`,
            color && `text_color_${color}`,
            `text_align_${align}`,
            className && className
        )}
    >
        {children}
    </p>