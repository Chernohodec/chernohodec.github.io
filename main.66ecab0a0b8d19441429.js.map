import React from "react"
import classNames from "classnames"
import './Button.css'

export const Button = ({ onClick, children, color="yellow", size="normal", href, disabled, className }) => {
    if (href) {
        return <a onClick={onClick} href={href} className={classNames("button", size && `button_size_${size}`, color && `button_color_${color}`, className && className)} target="_blank">
            <span>{children}</span>
        </a>
    } else {
        return <button disabled={disabled} onClick={onClick} className={classNames("button", size && `button_size_${size}`, color && `button_color_${color}`, className && className)}>
            <span>{children}</span>
        </button>
    }
}