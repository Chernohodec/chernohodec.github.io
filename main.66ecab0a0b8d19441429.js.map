import React, { useEffect, useState } from 'react'
import { useDispatch, useSelector } from "react-redux"
import { setActivePanel } from "../store/mainReducer"

const Loading = () => {
    const dispatch = useDispatch()

    const [isLoaded, setIsLoaded] = useState(false)
    const onboardingCompleted = useSelector(state => state.main.onboardingCompleted)
    const isFetched = useSelector(state => state.main.isFetched)
    const isLetterSend = useSelector(state => state.main.isLetterSend)
    const appIsOpen = useSelector(state => state.main.appIsOpen)

    useEffect(() => {

        const loading = setTimeout(() => {
            // dispatch(setActivePanel('onboardingStart'))
            setIsLoaded(true)
        }, 2500);
        return () => clearTimeout(loading);

    }, []);

    useEffect(() => {
        if (isFetched && isLoaded) {
            !appIsOpen ? dispatch(setActivePanel('final')) :
                isLetterSend ? dispatch(setActivePanel('result')) :
                    onboardingCompleted ? dispatch(setActivePanel('main')) :
                        dispatch(setActivePanel('onboardingStart'))
        }
    }, [isFetched, isLoaded, isLetterSend, onboardingCompleted])

    return (
        <div className="container loading-page">
            <img className="loading-page__main-pic" width="170" src="assets/images/logo.svg" loading="lazy" decoding="async" alt="logo" />
            <div className="loading-block loading-page__loading-block">
                <div className="loading-block__bar"></div>
            </div>
        </div>
    );
}


export default Loading;

