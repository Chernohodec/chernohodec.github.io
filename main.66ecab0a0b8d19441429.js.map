import React from "react"
import classNames from "classnames"
import './Title.css'

export const Title = ({ children, size = "normal", color = "black", align="center", className }) =>
    <p className={
        classNames(
            "title",
            size && `title_size_${size}`,
            color && `title_color_${color}`,
            align && `title_align_${align}`,
            className && className
        )}
    >
        {children}
    </p>